<Window x:Class="InboxDock.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:icons="http://metro.mahapps.com/winfx/xaml/iconpacks" Width="340" Height="480" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize" AllowDrop="True" Drop="OnDrop" DragEnter="OnDragEnter" DragLeave="OnDragLeave">
 <Window.Resources>
  <Style TargetType="Button"><Setter Property="BorderThickness" Value="0"/><Setter Property="Background" Value="Transparent"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Padding" Value="10,7"/></Style>
  <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
  <Style TargetType="TextBox"><Setter Property="Padding" Value="10"/><Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="Background" Value="White"/><Setter Property="TextWrapping" Value="Wrap"/></Style>
  <Style TargetType="TabItem"><Setter Property="Foreground" Value="{StaticResource Muted}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TabItem"><Border x:Name="TabSurface" Padding="16,7" Margin="0,0,6,0" CornerRadius="4" Background="Transparent"><ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsSelected" Value="True"><Setter TargetName="TabSurface" Property="Background" Value="{StaticResource AccentSoft}"/><Setter Property="Foreground" Value="{StaticResource Accent}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
 </Window.Resources>
 <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8">
  <Grid><Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition/><RowDefinition Height="42"/></Grid.RowDefinitions>
   <Grid Background="{StaticResource Surface}" MouseLeftButtonDown="OnHeaderDrag"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="44"/><ColumnDefinition Width="44"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
    <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center"><icons:PackIconLucide Kind="Inbox" Width="20" Foreground="{StaticResource Accent}"/><TextBlock Text="InboxDock" Margin="8,0" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/></StackPanel>
    <Button Grid.Column="1" Click="OnPin" ToolTip="在最前"><icons:PackIconLucide Kind="Pin" Width="18"/></Button>
    <Button Grid.Column="2" Click="OnCollapse" ToolTip="收起"><icons:PackIconLucide Kind="PanelRightClose" Width="18"/></Button>
    <Button Grid.Column="3" Click="OnSettings" ToolTip="设置 Vault"><icons:PackIconLucide Kind="Settings" Width="18"/></Button>
   </Grid>
   <TabControl Grid.Row="1" Margin="12" BorderThickness="0" Background="Transparent">
    <TabItem Header="收集"><Grid Margin="0,12,0,0"><Grid.RowDefinitions><RowDefinition Height="108"/><RowDefinition Height="10"/><RowDefinition/><RowDefinition Height="44"/></Grid.RowDefinitions>
     <Border x:Name="DropZone" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Background="White"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><icons:PackIconLucide Kind="FileDown" Width="28" Foreground="{StaticResource Accent}"/><TextBlock Text="把文件拖到这里" FontWeight="SemiBold" Margin="0,8,0,2"/><TextBlock Text="支持多个文件" Foreground="{StaticResource Muted}" FontSize="12"/></StackPanel></Border>
     <TextBox Grid.Row="2" Text="{Binding CaptureText,UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
     <Button Grid.Row="3" Style="{StaticResource Primary}" Click="OnCaptureText" Margin="0,8,0,0" IsEnabled="{Binding HasVault}"><TextBlock Text="收进 Inbox"/></Button>
    </Grid></TabItem>
    <TabItem Header="今日"><Grid Margin="0,12,0,0"><Grid.RowDefinitions><RowDefinition Height="36"/><RowDefinition Height="10"/><RowDefinition/><RowDefinition Height="44"/></Grid.RowDefinitions>
     <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Label" Padding="8"/>
     <TextBox Grid.Row="2" Text="{Binding DailyText,UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
     <Button Grid.Row="3" Style="{StaticResource Primary}" Click="OnAppendDaily" Margin="0,8,0,0" IsEnabled="{Binding HasVault}"><TextBlock Text="追加到 Daily"/></Button>
    </Grid></TabItem>
   </TabControl>
   <Grid Grid.Row="2" Background="White"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions><TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Muted}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="12,0" VerticalAlignment="Center"/><Button Grid.Column="1" Click="OnUndo" IsEnabled="{Binding CanUndo}" ToolTip="撤销上一次"><icons:PackIconLucide Kind="Undo2" Width="17"/></Button></Grid>
  </Grid>
 </Border>
</Window>
